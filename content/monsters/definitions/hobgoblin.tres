[gd_resource type="Resource" script_class="MonsterDefinition" format=3]

[ext_resource type="Script" path="res://content/abilities/resources/ability_definition.gd" id="1_ability"]
[ext_resource type="Script" path="res://content/monsters/resources/monster_definition.gd" id="1_monster"]
[ext_resource type="Script" path="res://content/dice/resources/dice_definition.gd" id="2_dice"]
[ext_resource type="Texture2D" path="res://assets/entity/monsters/goblin.png" id="3_sprite"]
[ext_resource type="Resource" path="res://content/abilities/definitions/hobgoblin_club_strike.tres" id="4_hobgoblin_club_strike"]
[ext_resource type="Resource" path="res://content/abilities/definitions/hobgoblin_rage.tres" id="5_hobgoblin_rage"]
