[resource]
script = ExtResource("1_monster")
monster_id = "hobgoblin"
display_name = "Хобгоблин"
description = "Силовой боец: сначала бьет дубиной по игроку, затем уходит в ярость, если больше не может атаковать."
sprite = ExtResource("3_sprite")
tags = PackedStringArray("normal", "goblin", "brute")
max_health = 50
size_multiplier = 0.8
dice_count = 2
dice_loadout = Array[ExtResource("2_dice")]([ExtResource("7_base_cube"), ExtResource("7_base_cube")])
ai_profile = ExtResource("6_ai")
abilities = Array[ExtResource("1_ability")]([ExtResource("4_hobgoblin_club_strike"), ExtResource("5_hobgoblin_rage")])
