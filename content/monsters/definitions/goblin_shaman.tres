[resource]
script = ExtResource("1_monster")
monster_id = "goblin_shaman"
display_name = "Гоблин-шаман"
description = "Элитный противник для затяжного боя: раздает дебаффы, накладывает миазмы и восстанавливает здоровье."
sprite = ExtResource("3_sprite")
tags = PackedStringArray("elite", "goblin", "shaman")
max_health = 80
size_multiplier = 0.9
dice_count = 4
dice_loadout = Array[ExtResource("2_dice")]([ExtResource("8_base_cube"), ExtResource("8_base_cube"), ExtResource("8_base_cube"), ExtResource("8_base_cube")])
