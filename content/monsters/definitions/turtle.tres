[ext_resource type="Script" path="res://content/monsters/resources/monster_definition.gd" id="1_monster"]
[ext_resource type="Script" path="res://content/dice/resources/dice_definition.gd" id="2_dice"]
[ext_resource type="Texture2D" path="res://assets/entity/monsters/turtle.png" id="3_sprite"]
[ext_resource type="Resource" path="res://content/abilities/definitions/turtle_defense.tres" id="4_turtle_defense"]
[ext_resource type="Resource" path="res://content/abilities/definitions/turtle_durability.tres" id="5_turtle_durability"]
[ext_resource type="Resource" path="res://content/abilities/definitions/turtle_bite.tres" id="6_turtle_bite"]
