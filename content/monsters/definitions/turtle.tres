[resource]
script = ExtResource("1_monster")
monster_id = "turtle"
display_name = "Черепаха"
description = "Выносливый монстр, который сначала наращивает стойкость и броню, а затем кусает врага, усиливая укус своей броней."
sprite = ExtResource("3_sprite")
tags = PackedStringArray("normal", "beast", "defender")
max_health = 50
size_multiplier = 0.8
dice_count = 3
dice_loadout = Array[ExtResource("2_dice")]([ExtResource("8_base_cube"), ExtResource("8_base_cube"), ExtResource("8_base_cube")])
ai_profile = ExtResource("7_ai")
abilities = Array[ExtResource("1_ability")]([ExtResource("5_turtle_durability"), ExtResource("4_turtle_defense"), ExtResource("6_turtle_bite")])
