[gd_resource type="Resource" script_class="AbilityDefinition" format=3]

[ext_resource type="Script" uid="uid://hkq3wkhbbh1u" path="res://content/abilities/resources/ability_definition.gd" id="1_ability"]
[ext_resource type="Script" uid="uid://cijja5c0f6ibw" path="res://content/abilities/resources/ability_cost.gd" id="2_cost"]
[ext_resource type="Script" uid="uid://vqakigfsnb18" path="res://content/abilities/resources/ability_dice_condition.gd" id="3_dice_condition"]
[ext_resource type="Script" uid="uid://c2t7x3op44t3s" path="res://content/abilities/resources/ability_target_rule.gd" id="4_target_rule"]
[ext_resource type="Script" uid="uid://drneiu6png0u3" path="res://content/abilities/resources/ability_effect_definition.gd" id="6_effect"]
[ext_resource type="Texture2D" uid="uid://ch8jyy4v7upmo" path="res://assets/ability/strengthening.png" id="7_icon"]

[sub_resource type="Resource" id="AbilityDiceCondition_any"]
script = ExtResource("3_dice_condition")
min_value = 1
max_value = 6
required_tags = PackedStringArray()
forbidden_tags = PackedStringArray()
accepted_face_ids = PackedStringArray()
consume_order = PackedStringArray()

[sub_resource type="Resource" id="AbilityCost_main"]
script = ExtResource("2_cost")
dice_conditions = Array[ExtResource("3_dice_condition")]([SubResource("AbilityDiceCondition_any")])
additional_costs = {
"max_dice_count": 3,
"min_dice_count": 1,
"required_dice_sum": 9
}

[sub_resource type="Resource" id="AbilityEffect_strength"]
script = ExtResource("6_effect")
effect_id = "strengthening_apply_strength"
effect_type = &"apply_status"
status_id = "strength"
magnitude = 2
dice_query_tags = PackedStringArray()

[sub_resource type="Resource" id="AbilityTargetRule_self"]
script = ExtResource("4_target_rule")
side = 3
selection = 0
min_targets = 0
max_targets = 0
allow_self = true
required_tags = PackedStringArray()
forbidden_tags = PackedStringArray()

[resource]
script = ExtResource("1_ability")
ability_id = "strengthening"
display_name = "Усиление"
description = "Требует кубы с суммой 9 (не более 3 кубов). Накладывает Сила +2."
icon = ExtResource("7_icon")
tags = PackedStringArray("support", "status")
owner_scope = 0
cost = SubResource("AbilityCost_main")
target_rule = SubResource("AbilityTargetRule_self")
effects = Array[ExtResource("6_effect")]([SubResource("AbilityEffect_strength")])
follow_up_ability_ids = PackedStringArray()
