[gd_resource type="Resource" script_class="AbilityDefinition" format=3]

[ext_resource type="Script" path="res://content/abilities/resources/ability_definition.gd" id="1_ability"]
[ext_resource type="Script" path="res://content/abilities/resources/ability_cost.gd" id="2_cost"]
[ext_resource type="Script" path="res://content/abilities/resources/ability_target_rule.gd" id="3_target_rule"]
[ext_resource type="Script" path="res://content/abilities/resources/ability_effect_definition.gd" id="4_effect"]
[ext_resource type="Texture2D" path="res://assets/ability/reroll.png" id="5_icon"]

[sub_resource type="Resource" id="AbilityCost_reroll"]
script = ExtResource("2_cost")
dice_conditions = Array[Resource]([])

[sub_resource type="Resource" id="AbilityEffect_reroll_selected_dice"]
script = ExtResource("4_effect")
effect_id = "reroll_selected_dice"
effect_type = &"reroll_dice"
dice_query_tags = PackedStringArray()

[sub_resource type="Resource" id="AbilityTargetRule_dice"]
script = ExtResource("3_target_rule")
side = 2
selection = 1
min_targets = 1
max_targets = 1
allow_self = true
required_tags = PackedStringArray()
forbidden_tags = PackedStringArray()

[resource]
script = ExtResource("1_ability")
ability_id = "reroll"
display_name = "Переброс кубика"
description = "Раз в ход перебрасывает выбранный куб."
icon = ExtResource("5_icon")
tags = PackedStringArray("utility", "reroll")
owner_scope = 0
rarity = 1
cooldown_turns = 1
cost = SubResource("AbilityCost_reroll")
target_rule = SubResource("AbilityTargetRule_dice")
effects = Array[Resource]([SubResource("AbilityEffect_reroll_selected_dice")])
follow_up_ability_ids = PackedStringArray()
