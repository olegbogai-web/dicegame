[gd_resource type="Resource" script_class="AbilityDefinition" format=3]

[ext_resource type="Script" path="res://content/abilities/resources/ability_definition.gd" id="1_ability"]
[ext_resource type="Script" path="res://content/abilities/resources/ability_cost.gd" id="2_cost"]
[ext_resource type="Script" path="res://content/abilities/resources/ability_target_rule.gd" id="3_target_rule"]
[ext_resource type="Script" path="res://content/abilities/resources/ability_effect_definition.gd" id="4_effect"]
[ext_resource type="Texture2D" path="res://assets/ability/reroll_all.png" id="5_icon"]

[sub_resource type="Resource" id="AbilityCost_reroll_all"]
script = ExtResource("2_cost")

[sub_resource type="Resource" id="AbilityEffect_reroll_all_remaining_player_dice"]
script = ExtResource("4_effect")
effect_id = "reroll_all_remaining_player_dice"
effect_type = &"reroll_dice"
parameters = {
"scope": "all_remaining_player_dice"
}

[sub_resource type="Resource" id="AbilityTargetRule_global"]
script = ExtResource("3_target_rule")
side = 2
selection = 0
allow_self = true

[resource]
script = ExtResource("1_ability")
ability_id = "reroll_all"
display_name = "Переброс всего"
description = "Перебрасывает все оставшиеся кубы."
icon = ExtResource("5_icon")
tags = PackedStringArray("utility", "reroll")
owner_scope = 0
rarity = 2
once_per_battle = true
cost = SubResource("AbilityCost_reroll_all")
target_rule = SubResource("AbilityTargetRule_global")
effects = Array[ExtResource("4_effect")]([SubResource("AbilityEffect_reroll_all_remaining_player_dice")])
follow_up_ability_ids = PackedStringArray()
