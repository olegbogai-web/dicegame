[resource]
script = ExtResource("1_ability")
ability_id = "reroll"
display_name = "Переброс кубика++"
description = "Перебрасывает выбранный кубик без отката, требует 1 любой кубик и снимает 1 стак случайного отрицательного состояния с владельца."
icon = ExtResource("6_icon")
