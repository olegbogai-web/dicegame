owner_scope = 0
rarity = 1
upgrade_level = 2
max_upgrade_level = 2
cost = SubResource("AbilityCost_reroll_any_die")
target_rule = SubResource("AbilityTargetRule_dice")
effects = Array[ExtResource("5_effect")]([SubResource("AbilityEffect_reroll_selected_dice_upgrade_2_2"), SubResource("AbilityEffect_cleanse_random_negative_status_upgrade_2_2")])
follow_up_ability_ids = PackedStringArray()
