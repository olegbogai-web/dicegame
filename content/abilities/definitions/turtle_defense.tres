[sub_resource type="Resource" id="AbilityCost_main"]
script = ExtResource("2_cost")
dice_conditions = Array[ExtResource("3_dice_condition")]([SubResource("AbilityDiceCondition_pay_3_or_5")])

[sub_resource type="Resource" id="AbilityEffect_apply_armor"]
script = ExtResource("6_effect")
