[sub_resource type="Resource" id="ArtifactTrigger_snake_tooth_on_turn_start"]
script = ExtResource("2_trigger")
trigger_id = "snake_tooth_on_turn_start"
event_name = &"on_turn_start"
effect_type = &"convert_status_to_status"
target_scope = &"self"
parameters = {
"apply_status_definition": ExtResource("4_regeneration_status"),
"remove_stacks": 2,
"remove_status_id": &"poison"
}

[resource]
script = ExtResource("1_artifact")
artifact_id = "snake_tooth"
display_name = "Зуб древней змеи"
description = "В начале хода снимает до 2 стаков «Яда». За каждый снятый стак накладывает 1 стак «Регенерации»."
rarity = &"unique"
sprite = ExtResource("3_icon")
tags = PackedStringArray("status", "poison", "regeneration", "turn_start")
triggers = Array[ExtResource("2_trigger")]([SubResource("ArtifactTrigger_snake_tooth_on_turn_start")])
metadata = {
&"debug_note": "snake_tooth_converts_poison_into_regeneration"
}
