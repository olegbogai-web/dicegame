[gd_resource type="Resource" script_class="StatusDefinition" format=3]

[ext_resource type="Script" path="res://content/statuses/resources/status_definition.gd" id="1_status"]
[ext_resource type="Script" path="res://content/statuses/resources/status_effect_definition.gd" id="2_effect"]
[ext_resource type="Texture2D" path="res://assets/states/dice_broken.png" id="3_icon"]

[sub_resource type="Resource" id="StatusEffect_disarmed_turn_start_dice_penalty"]
script = ExtResource("2_effect")
effect_id = "disarmed_turn_start_dice_penalty"
effect_type = &"disarm_dice_on_turn_start"
trigger = &"on_turn_start"
value = 1.0

[sub_resource type="Resource" id="StatusEffect_disarmed_clear_stacks"]
script = ExtResource("2_effect")
effect_id = "disarmed_clear_stacks"
effect_type = &"remove_status"
trigger = &"on_turn_end"
status_id = "disarmed"
parameters = {
"stacks": -1
}

[resource]
script = ExtResource("1_status")
status_id = "disarmed"
display_name = "Обезоружен"
description = "В начале хода владелец бросает на 1 куб меньше за каждый стак (случайный куб из доступных). В конце хода все стаки снимаются."
asset = ExtResource("3_icon")
category = 1
effects = Array[ExtResource("2_effect")]([SubResource("StatusEffect_disarmed_turn_start_dice_penalty"), SubResource("StatusEffect_disarmed_clear_stacks")])
