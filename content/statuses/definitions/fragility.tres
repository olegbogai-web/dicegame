[gd_resource type="Resource" script_class="StatusDefinition" format=3]

[ext_resource type="Script" path="res://content/statuses/resources/status_definition.gd" id="1_status"]
[ext_resource type="Script" path="res://content/statuses/resources/status_effect_definition.gd" id="2_effect"]
[ext_resource type="Texture2D" path="res://assets/states/vulnerability.png" id="3_icon"]

[sub_resource type="Resource" id="StatusEffect_fragility_incoming_damage_bonus"]
script = ExtResource("2_effect")
effect_id = "fragility_incoming_damage_bonus"
stat_key = &"ability_damage_incoming"
value = 1.0

[sub_resource type="Resource" id="StatusEffect_fragility_decay_on_damage_taken"]
script = ExtResource("2_effect")
effect_id = "fragility_decay_on_damage_taken"
effect_type = &"remove_status"
trigger = &"on_damage_taken"
status_id = "fragility"
parameters = {
"only_origin": &"ability",
"stacks": 1
}

[resource]
script = ExtResource("1_status")
status_id = "fragility"
opposite_status_id = "fortitude"
display_name = "Хрупкость"
description = "Пассивно увеличивает входящий урон от атак на 1 за каждый стак. При получении урона от атаки снимается 1 стак."
asset = ExtResource("3_icon")
effects = Array[ExtResource("2_effect")]([SubResource("StatusEffect_fragility_incoming_damage_bonus"), SubResource("StatusEffect_fragility_decay_on_damage_taken")])
metadata = {
"status_category": &"negative"
}
