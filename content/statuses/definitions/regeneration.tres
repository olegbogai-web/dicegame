[gd_resource type="Resource" script_class="StatusDefinition" format=3 uid="uid://drbrwun1o2b7j"]

[ext_resource type="Script" uid="uid://cr3rgro5ggg2o" path="res://content/statuses/resources/status_definition.gd" id="1_status"]
[ext_resource type="Script" uid="uid://desiurhox43nn" path="res://content/statuses/resources/status_effect_definition.gd" id="2_effect"]
[ext_resource type="Texture2D" uid="uid://bgajbo8ocrrtq" path="res://assets/states/regeneration.png" id="3_icon"]

[sub_resource type="Resource" id="StatusEffect_regeneration_heal_on_turn_start"]
script = ExtResource("2_effect")
effect_id = "regeneration_heal_on_turn_start"
effect_type = &"heal"
trigger = &"on_turn_start"
value = 1.0

[sub_resource type="Resource" id="StatusEffect_regeneration_decay"]
script = ExtResource("2_effect")
effect_id = "regeneration_decay"
effect_type = &"remove_status"
trigger = &"on_turn_end"
status_id = "regeneration"
parameters = {
"stacks": 1
}

[resource]
script = ExtResource("1_status")
status_id = "regeneration"
opposite_status_id = "bleeding"
display_name = "Регенерация"
description = "В начале хода восстанавливает 1 HP за каждый стак. В конце хода владельца снимается 1 стак."
asset = ExtResource("3_icon")
effects = Array[ExtResource("2_effect")]([SubResource("StatusEffect_regeneration_heal_on_turn_start"), SubResource("StatusEffect_regeneration_decay")])
metadata = {
"status_category": &"positive"
}
