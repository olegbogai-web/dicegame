[gd_resource type="Resource" script_class="StatusDefinition" format=3]

[ext_resource type="Script" path="res://content/statuses/resources/status_definition.gd" id="1_status"]
[ext_resource type="Script" path="res://content/statuses/resources/status_effect_definition.gd" id="2_effect"]
[ext_resource type="Texture2D" path="res://assets/states/regeneration.png" id="3_icon"]

[sub_resource type="Resource" id="StatusEffect_regeneration_turn_start_heal"]
script = ExtResource("2_effect")
effect_id = "regeneration_turn_start_heal"
effect_type = &"heal"
trigger = &"on_turn_start"
phase_order = 0
value = 1.0
target_scope = &"self"

[sub_resource type="Resource" id="StatusEffect_regeneration_turn_start_decay"]
script = ExtResource("2_effect")
effect_id = "regeneration_turn_start_decay"
effect_type = &"remove_status"
trigger = &"on_turn_start"
phase_order = 1
target_scope = &"self"
status_id = "regeneration"
parameters = {
"stacks": 1
}

[resource]
script = ExtResource("1_status")
status_id = "regeneration"
display_name = "Регенерация"
description = "В начале хода восстанавливает 1 HP за каждый стак, затем уменьшает количество стаков на 1."
asset = ExtResource("3_icon")
max_stacks = 99
effects = Array[ExtResource("2_effect")]([SubResource("StatusEffect_regeneration_turn_start_heal"), SubResource("StatusEffect_regeneration_turn_start_decay")])
