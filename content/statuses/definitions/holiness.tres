[gd_resource type="Resource" script_class="StatusDefinition" format=3]

[ext_resource type="Script" path="res://content/statuses/resources/status_definition.gd" id="1_status"]
[ext_resource type="Script" path="res://content/statuses/resources/status_effect_definition.gd" id="2_effect"]
[ext_resource type="Texture2D" path="res://assets/states/holiness.png" id="3_icon"]

[sub_resource type="Resource" id="StatusEffect_holiness_incoming_healing_bonus"]
script = ExtResource("2_effect")
effect_id = "holiness_incoming_healing_bonus"
stat_key = &"ability_healing_incoming"
value = 1.0

[resource]
script = ExtResource("1_status")
status_id = "holiness"
display_name = "Святость"
description = "Пассивно увеличивает получаемое исцеление на 1 за каждый стак. Не сбрасывается в конце хода."
asset = ExtResource("3_icon")
effects = Array[ExtResource("2_effect")]([SubResource("StatusEffect_holiness_incoming_healing_bonus")])
metadata = {
"status_category": &"positive"
}
