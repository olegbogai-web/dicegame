[resource]
script = ExtResource("1_status")
status_id = "poisonous_miasma"
display_name = "Ядовитые миазмы"
description = "В конце хода владельца накладывает на всех врагов состояние «Яд» в количестве стаков, равном стакам «Ядовитых миазмов». Не уменьшается."
asset = ExtResource("3_icon")
effects = Array[ExtResource("2_effect")]([SubResource("StatusEffect_poisonous_miasma_apply_poison_to_all_enemies")])
metadata = {
"status_category": &"positive"
}
