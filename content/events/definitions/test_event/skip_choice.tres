[gd_resource type="Resource" script_class="EventChoiceDefinition" format=3]

[ext_resource type="Script" path="res://content/events/resources/event_choice_definition.gd" id="1_choice"]
[ext_resource type="Script" path="res://content/events/resources/event_outcome_definition.gd" id="2_outcome"]
[ext_resource type="Resource" path="res://content/events/definitions/test_event/skip_choice_dice.tres" id="3_dice"]

[sub_resource type="Resource" id="Outcome_green"]
script = ExtResource("2_outcome")
outcome_color = "green"
outcome_text = "вам улыбнулась удача"

[sub_resource type="Resource" id="Outcome_yellow"]
script = ExtResource("2_outcome")
outcome_color = "yellow"
outcome_text = "ничего не произошло"

[sub_resource type="Resource" id="Outcome_red"]
script = ExtResource("2_outcome")
outcome_color = "red"
outcome_text = "ничего не произошло"

[resource]
script = ExtResource("1_choice")
choice_id = &"skip"
choice_text = "Пройти мимо"
event_dice_definition = ExtResource("3_dice")
positive_outcome = SubResource("Outcome_green")
neutral_outcome = SubResource("Outcome_yellow")
negative_outcome = SubResource("Outcome_red")
